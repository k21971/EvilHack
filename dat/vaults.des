FLAGS:rndvault
MINDEPTH:5
ROOM:"rndvault", random, random, random, random {
  MONSTER:(' ',"ghost"),random,asleep
  [65%]: OBJECT:(')',"dagger"), random, uncursed
  [55%]: OBJECT:')', random, uncursed
  [45%]: OBJECT:(')',"bow"), random, uncursed
  [45%]: OBJECT:(')',"arrow"), random, uncursed, quantity:2d6
  [65%]: OBJECT:'[', random, uncursed
  [20%]: OBJECT:'=', random
  [20%]: OBJECT:'?', random
}

