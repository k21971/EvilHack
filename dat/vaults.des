# generic trap room
LEVEL:"vlt-0038"
FLAGS:rndvault
MINDEPTH:6
ROOM:"rndvault", random, random, random, random {
  SWITCH [1d8] {
    CASE 1:
      LOOP [1d6 + 2] { TRAP:"arrow", random }
      BREAK
    CASE 2:
      LOOP [1d6 + 2] { TRAP:"dart", random }
      BREAK
    CASE 3:
      LOOP [1d6 + 2] { TRAP:"falling rock", random }
      BREAK
    CASE 4:
      LOOP [1d6 + 2] { TRAP:"bear", random }
      BREAK
    CASE 5:
      LOOP [1d6 + 2] { TRAP:"land mine", random }
      BREAK
    CASE 6:
      LOOP [1d6 + 2] { TRAP:"sleep gas", random }
      BREAK
    CASE 7:
      LOOP [1d6 + 2] { TRAP:"rust", random }
      BREAK
    CASE 8:
      LOOP [1d6 + 2] { TRAP:"anti magic", random }
      BREAK
  }
}

