MINDEPTH:5
GEOMETRY:random
MAP
--------
|......|
|......|
|------|
|......|
|......|
|......|
--------
ENDMAP
IF [40%] {
  $terr = TERRAIN:{ 'L', 'F' }
  SHUFFLE: $terr
  REPLACE_TERRAIN:(1,3,6,3),'-', $terr[0],100%
}
REGION:(1,1,6,2),random,"ordinary",unfilled { }
REGION:(1,4,6,6),random,"ordinary",unfilled { }

