}

# bazaar
LEVEL:"vlt-0045"
FLAGS:rndvault
MINDEPTH:8
ROOM:"rndvault", lit, random, random, (9,9) {
  SWITCH [1d4] {
    CASE 1:
      SUBROOM:"weapon shop", lit, (0,0), (3,3) {
        ROOMDOOR:random, random, south|east, random
      }
      SUBROOM:"armor shop", lit, (6,0), (3,3) {
        ROOMDOOR:random, random, south|west, random
      }
      SUBROOM:"food shop", lit, (0,6), (3,3) {
        ROOMDOOR:random, random, north|east, random
      }
      SUBROOM:"tool shop", lit, (6,6), (3,3) {
        ROOMDOOR:random, random, north|west, random
      }
      BREAK
    CASE 2:
      SUBROOM:"scroll shop", lit, (0,0), (3,3) {
        ROOMDOOR:random, random, south|east, random
      }
      SUBROOM:"potion shop", lit, (6,0), (3,3) {
        ROOMDOOR:random, random, south|west, random
      }
      SUBROOM:"wand shop", lit, (0,6), (3,3) {
        ROOMDOOR:random, random, north|east, random
      }
      SUBROOM:"book shop", lit, (6,6), (3,3) {
        ROOMDOOR:random, random, north|west, random
      }
      BREAK
    CASE 3:
      SUBROOM:"armor shop", lit, (0,0), (3,3) {
        ROOMDOOR:random, random, south|east, random
      }
      SUBROOM:"ring shop", lit, (6,0), (3,3) {
        ROOMDOOR:random, random, south|west, random
      }
      SUBROOM:"weapon shop", lit, (0,6), (3,3) {
        ROOMDOOR:random, random, north|east, random
      }
      SUBROOM:"scroll shop", lit, (6,6), (3,3) {
        ROOMDOOR:random, random, north|west, random
      }
      BREAK
    CASE 4:
      SUBROOM:"tool shop", lit, (0,0), (3,3) {
        ROOMDOOR:random, random, south|east, random
      }
      SUBROOM:"food shop", lit, (6,0), (3,3) {
        ROOMDOOR:random, random, south|west, random
      }
      SUBROOM:"potion shop", lit, (0,6), (3,3) {
        ROOMDOOR:random, random, north|east, random
      }
      SUBROOM:"armor shop", lit, (6,6), (3,3) {
        ROOMDOOR:random, random, north|west, random
      }
      BREAK
  }
}

