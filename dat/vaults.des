  $terr = TERRAIN: { 'F', 'L', 'P' }
  SHUFFLE: $terr
  TERRAIN:(0,2),$terr[0]
  TERRAIN:(1,2),$terr[0]
  TERRAIN:(2,2),$terr[0]
  TERRAIN:(3,2),$terr[0]
  TERRAIN:(4,2),$terr[0]
  TERRAIN:(5,2),$terr[0]
